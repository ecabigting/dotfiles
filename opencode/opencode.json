{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "chrome-devtools-mcp@latest"
      ],
    },
    "firefox-devtools": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "firefox-devtools-mcp@latest",
        "--profile-path",
        "/path/to/firefox-dev-profile/"
      ],
      "environment": {
        "START_URL": "about:home"
      }
    },
  }
}
